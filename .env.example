# =============================================================================
# AP Invoice & Contract Exception Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# -----------------------------------------------------------------------------
# OpenRouter — LLM backend (OpenAI-compatible endpoint)
# https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# -----------------------------------------------------------------------------
# Model
# Any model slug supported by OpenRouter:
#   https://openrouter.ai/models
# Examples:
#   google/gemini-2.5-flash
#   openai/gpt-4o-mini
#   anthropic/claude-3-haiku
#   meta-llama/llama-3.1-8b-instruct
# -----------------------------------------------------------------------------
MODEL=google/gemini-2.5-flash

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs

# -----------------------------------------------------------------------------
# Audit
# -----------------------------------------------------------------------------
AUDIT_DIR=audit
AUDIT_FILE=audit_log.jsonl

# -----------------------------------------------------------------------------
# Processing Thresholds
# -----------------------------------------------------------------------------
# Maximum % price variance before flagging as exception (default 5%)
PRICE_VARIANCE_THRESHOLD=5.0
# Maximum % quantity variance before flagging as exception (default 2%)
QUANTITY_VARIANCE_THRESHOLD=2.0

# -----------------------------------------------------------------------------
# OCR (Tesseract — optional, used for scanned PDFs/images)
# Leave blank if Tesseract is not installed; text-only PDFs will still work.
# -----------------------------------------------------------------------------
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
